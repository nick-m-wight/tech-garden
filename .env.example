# Environment configuration template.
# Copy to .env.dev or .env.prod and fill in values.
# NEVER commit a populated .env file (see .gitignore).
# Source of truth for this file: CLAUDE.md Section 5.

# --- App ---
# 'development' or 'production'
NODE_ENV=
PORT=3000
# generate with: openssl rand -base64 64
APP_SECRET=

# --- Auth ---
# path to RS256 private key PEM
JWT_PRIVATE_KEY_PATH=
# path to RS256 public key PEM
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# --- Claude API (optional — leave blank to disable plant analysis) ---
# NEVER commit this value
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Home Assistant (optional — leave blank to disable HA features) ---
# e.g. http://homeassistant.local:8123
HA_BASE_URL=
# HA long-lived access token — NEVER commit
HA_TOKEN=
# HMAC secret for HA webhook validation
HA_WEBHOOK_SECRET=

# --- Storage ---
# generate with: openssl rand -base64 32
PHOTO_ENCRYPTION_KEY=
DB_PATH=./data/app.db
PHOTO_STORAGE_PATH=./data/photos
PHOTO_RETENTION_DAYS=90

# --- Supabase (optional — leave all three blank to disable cloud sync) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# secret service key — backend only, NEVER put in mobile app
SUPABASE_SERVICE_KEY=

# --- Remote access (add vars here when remote access method is chosen) ---
# See infra/remote-access/OPTIONS.md
LOG_DIR=./logs
LOG_LEVEL=info                   # 'debug' in dev, 'info' or 'warn' in prod

# --- CORS ---
# Comma-separated list of allowed origins for browser callers.
# Native mobile (Expo/iOS/Android) does not send Origin and is unaffected.
# Leave blank in prod to only allow native clients.
CORS_ALLOWED_ORIGINS=

# --- MentraOS (smart glasses) ---
# Obtain MENTRA_PACKAGE_NAME and MENTRA_API_KEY from https://console.mentra.glass
# Both must be set together. Leave both blank to skip the glasses AppServer
# (useful for backend-only dev before registering the app).
MENTRA_PACKAGE_NAME=
MENTRA_API_KEY=
MENTRA_PORT=7010

