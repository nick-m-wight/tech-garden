{
  "name": "@local/base-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Base backend — reusable, secure template for MentraOS smart glasses apps",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "start": "node dist/app.js",
    "create-user": "tsc && node dist/scripts/createUser.js",
    "audit:strict": "npm audit --audit-level=high"
  },
  "overrides": {
    "jsonwebtoken": "9.0.3"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@mentra/sdk": "2.1.29",
    "bcryptjs": "2.4.3",
    "better-sqlite3": "11.1.2",
    "cors": "2.8.5",
    "express": "^4.22.2",
    "express-rate-limit": "7.4.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.3",
    "winston": "3.13.1",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/better-sqlite3": "7.6.11",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.10",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^3.0.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.3"
  }
}
