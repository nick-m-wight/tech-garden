# Copy this to .env.development (dev) or .env.production (prod) and fill in values.
# Expo auto-loads .env.development when running `expo start`.
# EXPO_PUBLIC_* vars are baked in at Metro bundle time — never put secrets here.

# URL of the base backend (no trailing slash).
# Dev: point at your local machine's IP so the Android emulator can reach it.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# Supabase — only required when opting into cloud sync (§16 step 11).
# Leave blank to run fully local.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Log verbosity: debug | info | warn | error
EXPO_PUBLIC_LOG_LEVEL=debug
