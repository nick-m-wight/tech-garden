{
  "name": "@local/garden-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Garden app backend — extends base with HA, Claude Vision, plant analysis",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "jest",
    "audit:strict": "npm audit --audit-level=high",
    "seed:zones": "node --env-file=../../../.env.dev --import tsx ./scripts/seed-dev-zones.ts"
  },
  "overrides": {
    "jsonwebtoken": "9.0.3"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.30.0",
    "@mentra/sdk": "2.1.29",
    "axios": "^1.16.1",
    "bcryptjs": "2.4.3",
    "better-sqlite3": "11.1.2",
    "cors": "2.8.5",
    "express": "^4.22.2",
    "express-rate-limit": "7.4.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.3",
    "winston": "3.13.1",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/better-sqlite3": "7.6.11",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.10",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^3.0.1",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "tsx": "4.19.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.3"
  }
}
